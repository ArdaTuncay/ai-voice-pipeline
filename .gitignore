# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/

# --- Virtual environment ---
venv/
.venv/
env/

# --- Environment / secrets ---
.env
.env.*
!.env.example

# --- Data not yet under DVC (structure kept via .gitkeep) ---
data/raw/*
data/logs/*
!data/raw/.gitkeep
!data/logs/.gitkeep
# data/processed/, data/features/ and data/output/ are DVC-tracked (see data/.gitignore, *.dvc files)

